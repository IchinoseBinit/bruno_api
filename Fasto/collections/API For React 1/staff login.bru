meta {
  name: staff login
  type: http
  seq: 1
}

post {
  url: {{gateway}}/api/staff/login/
  body: json
  auth: inherit
}

body:json {
  {
      "username":"binay_staff",
      "password":"@Hunter123"
  }
}

settings {
  encodeUrl: true
}

