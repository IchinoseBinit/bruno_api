meta {
  name: Product Availability Details
  type: http
  seq: 6
}

get {
  url: {{gateway}}/products/100/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

settings {
  encodeUrl: true
}

example {
  name: Success
  
  request: {
    url: {{gateway}}/products
    method: GET
    mode: none
  }
  
