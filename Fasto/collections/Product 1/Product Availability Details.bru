    headers: {
      Date: Mon, 29 Apr 2024 08:20:57 GMT
      Server: WSGIServer/0.2 CPython/3.10.14
      Content-Type: application/json
      Vary: Accept
      Allow: GET, HEAD, OPTIONS
      X-Frame-Options: DENY
      Content-Length: 1306
      X-Content-Type-Options: nosniff
