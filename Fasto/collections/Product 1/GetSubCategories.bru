meta {
  name: GetSubCategories
  type: http
  seq: 1
}

get {
  url: {{gateway}}/subcategories?category_id=82
  body: none
  auth: bearer
}

params:query {
  category_id: 82
}

auth:bearer {
  token: {{accessToken}}
}

settings {
  encodeUrl: true
}

example {
  name: Success
  
  request: {
    url: {{gateway}}/categories
    method: GET
    mode: none
  }
  
  response: {
    headers: {
      Date: Thu, 25 Apr 2024 06:25:09 GMT
