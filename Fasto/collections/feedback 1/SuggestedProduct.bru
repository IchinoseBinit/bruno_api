example {
  name: success
  
  request: {
    url: {{gateway}}/feedback/suggested-products
    method: POST
    mode: json
    body:json: {
      {
        "product": "Khapsey",
        "description": "Crunchy snacks"
      }
      
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
      Vary: Accept, Cookie
      Allow: GET, POST, HEAD, OPTIONS
      X-Frame-Options: DENY
      Content-Length: 69
      X-Content-Type-Options: nosniff
      Referrer-Policy: same-origin
      Cross-Origin-Opener-Policy: same-origin
    }
  
    status: {
      code: 201
      text: Created
    }
  
    body: {
      type: json
      content: '''
        {
