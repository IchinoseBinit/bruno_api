meta {
  name: List
  type: http
  seq: 4
}

get {
  url: {{gateway}}/api/staff/list/?page=1&search=binit&store_id=1
  body: none
  auth: bearer
}

params:query {
  page: 1
  search: binit
  store_id: 1
}

auth:bearer {
  token: {{packerAccessToken}}
}

settings {
  encodeUrl: true
}

example {
  name: success
  
  request: {
    url: {{gateway}}/api/staff/list/?page=10
    method: GET
    mode: none
    params:query: {
      page: 10
    }
  }
  
