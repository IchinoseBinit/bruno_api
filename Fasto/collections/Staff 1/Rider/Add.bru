example {
  name: add
  
  request: {
    url: {{gateway}}/api/rider/add/
    method: POST
    mode: multipartForm
    body:multipart-form: {
      store: 3
      document_image: @file(postman-cloud:///1f07fe77-581d-4020-a002-52861fe27831)
      document_type: passport
      phone_number: 898989898111
      name: rider kto
      password: admin123
      username: og rider1233
      emergency_contact_number: 875858474111
    }
  }
  
