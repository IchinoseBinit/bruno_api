meta {
  name: Post Order Item
  type: http
  seq: 1
}

post {
  url: {{gateway}}/orders/order-item-modification/
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "order_id": 123,
    "product_id": 456,
    "quantity": 2
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
