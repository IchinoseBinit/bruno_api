meta {
  name: Feature Group List
  type: http
  seq: 3
}

get {
  url: {{gateway}}/feature/api/admin/feature-groups/
  body: json
  auth: bearer
}

headers {
  Authorization: Bearer <admin_token>
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

settings {
  encodeUrl: true
}
