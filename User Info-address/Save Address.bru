example {
  name: Success
  
  request: {
    url: {{gateway}}/user-info
    method: POST
    mode: json
    body:json: {
      {
          "address":"Basundhara",
          "name": "Home",
          "latitude": 87.2562,
          "longitude": 23.5873
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
      Vary: Accept
      Allow: GET, POST, HEAD, OPTIONS
      X-Frame-Options: DENY
      Content-Length: 154
      X-Content-Type-Options: nosniff
      Referrer-Policy: same-origin
      Cross-Origin-Opener-Policy: same-origin
    }
  
    status: {
      code: 201
      text: Created
    }
  
    body: {
      type: json
      content: '''
        {
            "success": true,
            "message": "UserInfo created successfully",
            "details": {
                "id": 14,
                "name": "Home",
                "address": "Basundhara",
                "latitude": 87.2562,
                "longitude": 23.5873
            }
        }
      '''
    }
  }
}
