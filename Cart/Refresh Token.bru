example {
  name: Invalid Refresh Token
  
  request: {
    url: {{gateway}}/auth/verify-otp/refresh/
    method: POST
    mode: json
    body:json: {
      {
          "refresh": "a.eyJ0b2tlbl90eXBlIjoicmVmcmVzaCIsImV4cCI6MTcxNDI5ODk0NywiaWF0IjoxNzEzNDM0OTQ3LCJqdGkiOiJkNjhiYzk1MDMzODE0NmIxYjIwOWU5ZmMwOTU1OThiNCIsInVzZXJfaWQiOjMyfQ.X-GtJ3okWvrN8SXaeKVW36et0x0sK1gTmKDT6LtbF0E"
         
          
