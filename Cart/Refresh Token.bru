example {
  name: Failed
  
  request: {
    url: {{gateway}}/auth/verify-otp
    method: POST
    mode: json
    body:json: {
      {
          "phone_number":"9818207179",
          "otp_code":"123123"
         
          
      }
    }
  }
  
  response: {
    headers: {
      Date: Thu, 18 Apr 2024 10:14:04 GMT
      Server: WSGIServer/0.2 CPython/3.10.14
      Content-Type: application/json
      Vary: Accept
      Allow: POST, OPTIONS
      X-Frame-Options: DENY
      Content-Length: 41
      X-Content-Type-Options: nosniff
      Referrer-Policy: same-origin
      Cross-Origin-Opener-Policy: same-origin
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
            "message": "OTP is not valid or expired"
        }
      '''
    }
  }
}

