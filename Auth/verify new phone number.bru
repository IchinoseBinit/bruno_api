example {
  name: success
  
  request: {
    url: {{gateway}}/auth/verify-and-change-phone-number/
    method: POST
    mode: json
    body:json: {
      {
        "new_phone_number":9768400312,
        "otp_code": 809468
      }
      
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
      Vary: Accept, Cookie
      Allow: POST, OPTIONS
      X-Frame-Options: DENY
      Content-Length: 63
      X-Content-Type-Options: nosniff
      Referrer-Policy: same-origin
      Cross-Origin-Opener-Policy: same-origin
    }
  
