meta {
  name: Create Feature Group
  type: http
  seq: 1
}

post {
  url: {{gateway}}/feature/api/admin/feature-groups/
  body: json
  auth: bearer
}

headers {
  Authorization: Bearer <admin_token>
  Content-Type: application/json
}

auth:bearer {
  token: {{packerAccessToken}}
}

body:json {
  {
      "name": "Order Management",
      "slug": "order_management",
      "icon": "order",
      "order": 0
    }
}

settings {
  encodeUrl: true
}
