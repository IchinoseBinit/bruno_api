example {
  name: Failed - For Unregistered User
  
  request: {
    url: {{gateway}}/auth/login/token/
    method: POST
    mode: json
    headers: {
      Content-Type: application/json
    }
  
    body:json: {
      {
          "phone_number": "0000000000"
      
      }
    }
  }
  
  response: {
    headers: {
      Date: Wed, 17 Apr 2024 10:21:51 GMT
      Server: WSGIServer/0.2 CPython/3.10.14
      Content-Type: application/json
      Vary: Accept
      Allow: POST, OPTIONS
      X-Frame-Options: DENY
      Content-Length: 59
      X-Content-Type-Options: nosniff
      Referrer-Policy: same-origin
      Cross-Origin-Opener-Policy: same-origin
    }
  
    status: {
      code: 404
      text: Not Found
    }
  
    body: {
      type: json
      content: '''
        {
            "error": "User with provided phone number does not exist."
        }
      '''
    }
  }
}

