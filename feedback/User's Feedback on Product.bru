body:json {
  {
    "feedback_text": "good and fresh product in affordable price"
  }
  
}

settings {
  encodeUrl: true
}

example {
  name: Success
  
  request: {
    url: {{gateway}}/feedback/
    method: GET
    mode: json
    body:json: {
      {
        "product": 7, 
        "feedback_text": "good and fresh mangoes in affordable price"
      }
      
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
      Vary: Accept, Cookie
      Allow: GET, POST, HEAD, OPTIONS
      X-Frame-Options: DENY
      Content-Length: 141
      X-Content-Type-Options: nosniff
      Referrer-Policy: same-origin
      Cross-Origin-Opener-Policy: same-origin
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        [
            {
                "id": 1,
                "product": 7,
                "user": 11,
                "feedback_text": "good and fresh mangoes in affordable price",
                "created_at": "2024-08-26T12:45:52.547965+05:45"
            }
        ]
      '''
    }
  }
}

example {
  name: success for post
  
  request: {
    url: {{gateway}}/feedback/
    method: POST
    mode: json
    body:json: {
      {
        "product": 1, 
        "feedback_text": "good and fresh product in affordable price"
      }
      
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
      Vary: Accept, Cookie
      Allow: GET, POST, HEAD, OPTIONS
      X-Frame-Options: DENY
      Content-Length: 139
      X-Content-Type-Options: nosniff
      Referrer-Policy: same-origin
      Cross-Origin-Opener-Policy: same-origin
    }
  
    status: {
      code: 201
      text: Created
    }
  
    body: {
      type: json
      content: '''
        {
            "id": 2,
            "product": 1,
            "user": 11,
            "feedback_text": "good and fresh product in affordable price",
            "created_at": "2024-08-26T12:47:47.120306+05:45"
        }
      '''
    }
  }
}
