                "total": "10324.50"
            }
        }
      '''
    }
  }
}

example {
  name: prepaid order
  
  request: {
    url: {{gateway}}/orders/2766/reach
    method: POST
    mode: none
  }
  
  response: {
    headers: {
      Content-Type: application/json
      Vary: Accept, origin, Cookie
      Allow: POST, OPTIONS
      X-Frame-Options: DENY
      Content-Length: 36
      X-Content-Type-Options: nosniff
      Referrer-Policy: same-origin
      Cross-Origin-Opener-Policy: same-origin
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
            "success": true,
            "payment_done": true
        }
      '''
    }
  }
}
